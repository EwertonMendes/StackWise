          Label #LogSuccess4 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning4 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError4 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
        Group #LogRow5 {
          Anchor: (Height: 58, Bottom: 6);
          LayoutMode: Full;

          Label #LogInfo5 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #LogSuccess5 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning5 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError5 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
        Group #LogRow6 {
          Anchor: (Height: 58, Bottom: 6);
          LayoutMode: Full;

          Label #LogInfo6 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #LogSuccess6 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning6 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError6 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
        Group #LogRow7 {
          Anchor: (Height: 58, Bottom: 6);
          LayoutMode: Full;

          Label #LogInfo7 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #LogSuccess7 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning7 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError7 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
        Group #LogRow8 {
          Anchor: (Height: 58, Bottom: 6);
          LayoutMode: Full;

          Label #LogInfo8 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #LogSuccess8 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning8 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError8 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
        Group #LogRow9 {
          Anchor: (Height: 58, Bottom: 6);
          LayoutMode: Full;

          Label #LogInfo9 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #LogSuccess9 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #LogWarning9 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #LogError9 { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }
      }

      Group {
        Anchor: (Height: 48, Top: 8);
        LayoutMode: Left;
        $Common.@SecondaryTextButton #PreviousButton { @Text = "Previous"; Anchor: (Width: 140, Height: 42, Right: 10); }
        Label #PageLabel { Style: (...$Common.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 42, Right: 10); Text: ""; }
        $Common.@SecondaryTextButton #NextButton { @Text = "Next"; Anchor: (Width: 140, Height: 42, Right: 10); }
        $Common.@SecondaryTextButton #BackButton { @Text = "Back"; Anchor: (Width: 140, Height: 42, Right: 10); }
        $Common.@CancelTextButton #ClosePageButton { @Text = "Close"; Anchor: (Width: 140, Height: 42); }
      }
    }
  }
}
