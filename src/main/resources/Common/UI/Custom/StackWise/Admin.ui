$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 1100, Height: 840);

    #Title {
      Label #AdminTitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "StackWise Administration";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 12, Bottom: 12, Left: 18, Right: 18);

      Group #TabBar {
        Anchor: (Height: 48, Bottom: 8);
        LayoutMode: Left;

        $Common.@TextButton #RulesTabActive { @Text = "Rules"; Anchor: (Width: 220, Height: 42, Right: 8); }
        $Common.@SecondaryTextButton #RulesTabInactive { @Text = "Rules"; Anchor: (Width: 220, Height: 42, Right: 8); Visible: false; }
        $Common.@TextButton #SettingsTabActive { @Text = "Global settings"; Anchor: (Width: 220, Height: 42); Visible: false; }
        $Common.@SecondaryTextButton #SettingsTabInactive { @Text = "Global settings"; Anchor: (Width: 220, Height: 42); }
      }

      Group #StatusGroup {
        Anchor: (Height: 44, Bottom: 6);
        LayoutMode: Full;
        Visible: false;

        Label #StatusInfoLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
        Label #StatusSuccessLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
        Label #StatusWarningLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
        Label #StatusErrorLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
      }

      Group #ReportBar {
        Anchor: (Height: 50, Bottom: 8);
        LayoutMode: Left;

        Group {
          FlexWeight: 1;
          Anchor: (Height: 46, Right: 10);
          LayoutMode: Full;
          Label #ReportInfoLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96a9be); Text: ""; }
          Label #ReportSuccessLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #72c878); Text: ""; Visible: false; }
          Label #ReportWarningLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); Text: ""; Visible: false; }
          Label #ReportErrorLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e56b6f); Text: ""; Visible: false; }
        }

        $Common.@SecondaryTextButton #ViewLogButton { @Text = "View log"; Anchor: (Width: 160, Height: 42); }
      }

      Group #RulesTabContent {
        FlexWeight: 1;
        LayoutMode: Top;

        Group {
          Anchor: (Height: 48, Bottom: 8);
          LayoutMode: Left;

          Label #SearchLabel {
            Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center);
            Anchor: (Width: 120, Height: 38, Right: 10);
            Text: "Search rules";
          }

          $Common.@TextField #SearchField {
            Anchor: (Height: 38, Right: 8);
            FlexWeight: 1;
            PlaceholderText: "Rule id or item id/pattern";
            MaxLength: 256;
          }

          $Common.@SecondaryTextButton #SearchButton { @Text = "Search"; Anchor: (Width: 120, Height: 42, Right: 8); }
          $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Clear"; Anchor: (Width: 120, Height: 42); }
        }

        Group {
          Anchor: (Height: 46, Bottom: 8);
          LayoutMode: Left;

          $Common.@TextButton #NewRuleButton { @Text = "New rule"; Anchor: (Width: 170, Height: 42, Right: 8); }
          $Common.@SecondaryTextButton #ReloadButton { @Text = "Reload JSON"; Anchor: (Width: 190, Height: 42, Right: 8); }
          $Common.@SecondaryTextButton #ExportButton { @Text = "Export item catalog"; Anchor: (Width: 250, Height: 42); }
        }

        Group #RulesScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $Common.@DefaultScrollbarStyle;
          KeepScrollPosition: true;
          Padding: (Right: 10);

          Label #RulesLabel {
            Style: $Common.@DefaultLabelStyle;
            Anchor: (Height: 24, Bottom: 8);
            Text: "Stack rules";
          }

        Group #RuleRow0 {
          Anchor: (Height: 74, Bottom: 6);
          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            Anchor: (Height: 68, Right: 12);
            LayoutMode: Top;
            Label #RuleName0 { Style: $Common.@DefaultLabelStyle; Anchor: (Height: 28); Text: "Rule"; }
            Label #RuleDescription0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true); Anchor: (Height: 40); Text: "Rule details"; }
          }

          Group #RuleActions0 {
            Anchor: (Width: 302, Height: 50);
            LayoutMode: Left;
            $Common.@SecondaryTextButton #EditButton0 { @Text = "Edit"; Anchor: (Width: 120, Height: 44, Right: 10); }
            $Common.@CancelTextButton #DeleteButton0 { @Text = "Delete"; Anchor: (Width: 172, Height: 44); }
          }

          Group #DeleteConfirmation0 {
            Anchor: (Width: 690, Height: 62);
            LayoutMode: Left;
            Visible: false;

            Label #DeleteConfirmationLabel0 {
              Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f);
              FlexWeight: 1;
              Anchor: (Height: 58, Right: 10);
              Text: "";
            }

            $Common.@SecondaryTextButton #CancelDeleteButton0 { @Text = "Cancel"; Anchor: (Width: 120, Height: 44, Right: 10); }
            $Common.@CancelTextButton #ConfirmDeleteButton0 { @Text = "Confirm delete"; Anchor: (Width: 210, Height: 44); }
          }
        }
        Group #RuleRow1 {
          Anchor: (Height: 74, Bottom: 6);
          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            Anchor: (Height: 68, Right: 12);
            LayoutMode: Top;
            Label #RuleName1 { Style: $Common.@DefaultLabelStyle; Anchor: (Height: 28); Text: "Rule"; }
            Label #RuleDescription1 { Style: (...$Common.@DefaultLabelStyle, Wrap: true); Anchor: (Height: 40); Text: "Rule details"; }
          }

          Group #RuleActions1 {
            Anchor: (Width: 302, Height: 50);
            LayoutMode: Left;
            $Common.@SecondaryTextButton #EditButton1 { @Text = "Edit"; Anchor: (Width: 120, Height: 44, Right: 10); }
            $Common.@CancelTextButton #DeleteButton1 { @Text = "Delete"; Anchor: (Width: 172, Height: 44); }
          }

          Group #DeleteConfirmation1 {
