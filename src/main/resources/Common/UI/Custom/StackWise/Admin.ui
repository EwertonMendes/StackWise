            Label #DeleteConfirmationLabel1 {
              Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f);
              FlexWeight: 1;
              Anchor: (Height: 58, Right: 10);
              Text: "";
            }

            $Common.@SecondaryTextButton #CancelDeleteButton1 { @Text = "Cancel"; Anchor: (Width: 120, Height: 44, Right: 10); }
            $Common.@CancelTextButton #ConfirmDeleteButton1 { @Text = "Confirm delete"; Anchor: (Width: 210, Height: 44); }
          }
        }
