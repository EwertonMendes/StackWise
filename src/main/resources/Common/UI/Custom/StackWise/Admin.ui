          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            Anchor: (Height: 68, Right: 12);
            LayoutMode: Top;
            Label #RuleName7 { Style: $Common.@DefaultLabelStyle; Anchor: (Height: 28); Text: "Rule"; }
            Label #RuleDescription7 { Style: (...$Common.@DefaultLabelStyle, Wrap: true); Anchor: (Height: 40); Text: "Rule details"; }
          }

