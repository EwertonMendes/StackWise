      Group #SettingsTabContent {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        Group #SettingsScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $Common.@DefaultScrollbarStyle;
