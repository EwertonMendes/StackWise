            Label #DeleteConfirmationLabel3 {
              Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f);
              FlexWeight: 1;
              Anchor: (Height: 58, Right: 10);
              Text: "";
            }

            $Common.@SecondaryTextButton #CancelDeleteButton3 { @Text = "Cancel"; Anchor: (Width: 120, Height: 44, Right: 10); }
            $Common.@CancelTextButton #ConfirmDeleteButton3 { @Text = "Confirm delete"; Anchor: (Width: 210, Height: 44); }
          }
        }
        Group #RuleRow4 {
          Anchor: (Height: 74, Bottom: 6);
          LayoutMode: Left;

          Group {
            FlexWeight: 1;
            Anchor: (Height: 68, Right: 12);
            LayoutMode: Top;
            Label #RuleName4 { Style: $Common.@DefaultLabelStyle; Anchor: (Height: 28); Text: "Rule"; }
