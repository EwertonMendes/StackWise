        }

        Group {
          Anchor: (Height: 48, Top: 8);
          LayoutMode: Left;
          $Common.@SecondaryTextButton #PreviousButton { @Text = "Previous"; Anchor: (Width: 150, Height: 42, Right: 10); }
          Label #PageLabel { Style: (...$Common.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 42, Right: 10); Text: ""; }
          $Common.@SecondaryTextButton #NextButton { @Text = "Next"; Anchor: (Width: 150, Height: 42); }
        }
      }

      Group #SettingsTabContent {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        Group #SettingsScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $Common.@DefaultScrollbarStyle;
          KeepScrollPosition: true;
          Padding: (Right: 10);

          Label #GlobalSettingsLabel {
            Style: $Common.@DefaultLabelStyle;
            Anchor: (Height: 26, Bottom: 12);
            Text: "Global settings";
          }

          Group {
            Anchor: (Height: 118, Bottom: 12);
            LayoutMode: Left;

            Group {
              FlexWeight: 1;
              Anchor: (Right: 22);
              LayoutMode: Top;

              Group { Anchor: (Height: 34, Bottom: 4); LayoutMode: Left; $Common.@CheckBox #EnabledCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #EnabledLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Enable StackWise"; } }
              Group { Anchor: (Height: 34, Bottom: 4); LayoutMode: Left; $Common.@CheckBox #SafeModeCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #SafeModeLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Safe mode for non-stackable items"; } }
              Group { Anchor: (Height: 34); LayoutMode: Left; $Common.@CheckBox #RespectExternalChangesCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #RespectExternalChangesLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Respect stack changes made by other mods"; } }
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Group { Anchor: (Height: 34, Bottom: 4); LayoutMode: Left; $Common.@CheckBox #AllowDecreasesCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #AllowDecreasesLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Allow limits below the original value"; } }
              Group { Anchor: (Height: 34, Bottom: 4); LayoutMode: Left; $Common.@CheckBox #AllowRuntimeDecreasesCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #AllowRuntimeDecreasesLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Allow live decreases without restart"; } }
              Group { Anchor: (Height: 34); LayoutMode: Left; $Common.@CheckBox #RestoreUnmatchedCheck { Anchor: (Width: 22, Height: 22, Right: 10); } Label #RestoreUnmatchedLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 28); Text: "Restore items no longer matched by rules"; } }
            }
          }

          Group {
            Anchor: (Height: 52, Bottom: 10);
            LayoutMode: Left;
            $Common.@CheckBox #GlobalLimitEnabledCheck { Anchor: (Width: 22, Height: 22, Right: 10); }
            Label #GlobalLimitEnabledLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); Anchor: (Width: 285, Height: 38, Right: 14); Text: "Enable global stack limit"; }
            Label #GlobalStackLimitLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); Anchor: (Width: 190, Height: 38, Right: 12); Text: "Global stack limit"; }
            $Common.@NumberField #GlobalStackLimitInput { Anchor: (Width: 180, Height: 38); Format: (MaxDecimalPlaces: 0, Step: 1, MinValue: 1, MaxValue: 9999); }
          }

          Group {
            Anchor: (Height: 52, Bottom: 12);
            LayoutMode: Left;
            Label #MaximumStackLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); Anchor: (Width: 285, Height: 38, Right: 12); Text: "Maximum configurable stack"; }
            $Common.@NumberField #MaximumStackInput { Anchor: (Width: 180, Height: 38); Format: (MaxDecimalPlaces: 0, Step: 1, MinValue: 1, MaxValue: 9999); }
          }

          $Common.@TextButton #SaveGeneralButton { @Text = "Save settings"; Anchor: (Width: 240, Height: 44); }
        }
